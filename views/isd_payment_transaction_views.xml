<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Transaction Form View -->
    <record id="view_isd_payment_transaction_form" model="ir.ui.view">
        <field name="name">isd_payment.transaction.form</field>
        <field name="model">isd_payment.transaction</field>
        <field name="arch" type="xml">
            <form string="Payment Transaction" create="false" edit="false" delete="false">
                <header>
                    <field name="status" widget="statusbar" statusbar_visible="pending,processing,confirmed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="transaction_id" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="payment_method_id"/>
                            <field name="amount" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="description"/>
                        </group>
                        <group>
                            <field name="create_date" string="Created At"/>
                            <field name="confirmed_at"/>
                            <field name="expired_at"/>
                            <field name="is_expired" invisible="1"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Payment Info" name="payment_info">
                            <group>
                                <group string="QR Code">
                                    <field name="qr_url" widget="url"/>
                                    <label for="qr_url" string="QR Code Image" invisible="not qr_url"/>
                                    <div invisible="not qr_url">
                                        <a href="#" class="btn btn-primary" onclick="window.open(document.querySelector('[name=qr_url]').value, '_blank'); return false;">
                                            Open QR Code
                                        </a>
                                    </div>
                                </group>
                                <group string="Bank Details">
                                    <field name="bank_code"/>
                                    <field name="bank_account"/>
                                </group>
                            </group>
                        </page>

                        <page string="SePay Response" name="sepay_response" invisible="not sepay_transaction_id">
                            <group>
                                <group>
                                    <field name="sepay_transaction_id"/>
                                    <field name="sepay_reference"/>
                                </group>
                                <group>
                                    <field name="sepay_transaction_content"/>
                                </group>
                            </group>
                        </page>

                        <page string="API Request Info" name="api_info">
                            <group>
                                <group>
                                    <field name="request_origin"/>
                                    <field name="request_ip"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Transaction Tree View -->
    <record id="view_isd_payment_transaction_tree" model="ir.ui.view">
        <field name="name">isd_payment.transaction.tree</field>
        <field name="model">isd_payment.transaction</field>
        <field name="arch" type="xml">
            <list string="Transactions" create="false" delete="false" decoration-success="status == 'confirmed'" decoration-muted="status == 'expired'" decoration-danger="status == 'failed'">
                <field name="transaction_id"/>
                <field name="payment_method_id"/>
                <field name="amount" sum="Total Amount"/>
                <field name="status" widget="badge" decoration-success="status == 'confirmed'" decoration-info="status in ('pending', 'processing')" decoration-danger="status == 'failed'" decoration-muted="status == 'expired'"/>
                <field name="create_date" string="Created"/>
                <field name="confirmed_at"/>
                <field name="expired_at"/>
                <field name="request_origin"/>
                <field name="currency_id" column_invisible="True"/>
            </list>
        </field>
    </record>

    <!-- Transaction Search View -->
    <record id="view_isd_payment_transaction_search" model="ir.ui.view">
        <field name="name">isd_payment.transaction.search</field>
        <field name="model">isd_payment.transaction</field>
        <field name="arch" type="xml">
            <search string="Transactions">
                <field name="transaction_id" filter_domain="[('transaction_id','ilike',self)]"/>
                <field name="payment_method_id"/>
                <field name="amount"/>
                <separator/>
                <filter string="Pending" name="status_pending" domain="[('status','=','pending')]"/>
                <filter string="Processing" name="status_processing" domain="[('status','=','processing')]"/>
                <filter string="Confirmed" name="status_confirmed" domain="[('status','=','confirmed')]"/>
                <filter string="Failed" name="status_failed" domain="[('status','=','failed')]"/>
                <filter string="Expired" name="status_expired" domain="[('status','=','expired')]"/>
                <separator/>
                <filter string="Today" name="today" domain="[('create_date','&gt;=',context_today())]"/>
                <filter string="This Week" name="this_week" domain="[('create_date','&gt;=', (context_today() - relativedelta(weeks=1)))]"/>
                <filter string="This Month" name="this_month" domain="[('create_date','&gt;=', (context_today() - relativedelta(months=1)))]"/>
                <separator/>
                <filter string="Has SePay Response" name="has_sepay_response" domain="[('sepay_transaction_id','!=',False)]"/>
                <group expand="0" string="Group By">
                    <filter string="Payment Method" name="group_payment_method" context="{'group_by':'payment_method_id'}"/>
                    <filter string="Status" name="group_status" context="{'group_by':'status'}"/>
                    <filter string="Created Date" name="group_create_date" context="{'group_by':'create_date:day'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Transaction Action -->
    <record id="action_isd_payment_transaction" model="ir.actions.act_window">
        <field name="name">Transactions</field>
        <field name="res_model">isd_payment.transaction</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_today': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_empty_folder">
                No transactions yet
            </p>
            <p>
                Transactions are created automatically via API calls.
            </p>
        </field>
    </record>

    <!-- Add currency_id to transaction model for monetary widget -->
    <record id="view_isd_payment_transaction_form_currency" model="ir.ui.view">
        <field name="name">isd_payment.transaction.form.currency</field>
        <field name="model">isd_payment.transaction</field>
        <field name="inherit_id" ref="view_isd_payment_transaction_form"/>
        <field name="arch" type="xml">
            <field name="amount" position="before">
                <field name="currency_id" invisible="1"/>
            </field>
        </field>
    </record>

</odoo>
